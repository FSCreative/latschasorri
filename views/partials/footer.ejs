  <div class="footgrid">
    <div>
      <h4>Kontakt</h4>
      <a href="mailto:<%= s.email %>"><%= s.email %></a>
      <p class="motto"><%= s.motto %></p>
    </div>
    <div>
      <h4>Mehr von uns</h4>
      <a href="https://www.instagram.com/<%= s.instagramHandle %>/" target="_blank" rel="noopener">📸 Instagram @<%= s.instagramHandle %></a><br>
      <a href="<%= s.youtube %>" target="_blank" rel="noopener">▶ YouTube-Kanal</a><br>
      <a href="<%= s.archiveGallery %>" target="_blank" rel="noopener">🗄 Galerie-Archiv (alte Seite)</a><br>
      <a href="<%= s.cloud %>" target="_blank" rel="noopener">☁ Cloud (Archiv)</a>
    </div>
    <div>
      <h4>Intern</h4>
      <% if (admin) { %>
        <a href="/admin">⚙ Admin-Bereich</a><br>
        <form method="post" action="/admin/logout" style="display:inline"><button class="linkbtn" type="submit">Abmelden</button></form>
      <% } else { %>
        <a href="/admin/login">⚙ Admin-Login</a>
      <% } %>
    </div>
  </div>
  <p class="copyright">© <%= new Date().getFullYear() %> Guggamusik Partener Latschasorri · Partenen im Montafon</p>
</footer>

