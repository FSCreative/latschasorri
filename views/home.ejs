<%- include('partials/header') %>

<section class="hero">
  <div class="notes-fx" aria-hidden="true"><span>♪</span><span>♫</span><span>♪</span><span>♬</span><span>♪</span><span>♫</span></div>
  <div class="hero-inner reveal">
    <p class="eyebrow">Guggamusik aus Partenen · seit <%= s.since %></p>
    <h1>Ore Ore –<br><span class="grad">etz konn d'Latschasorri!</span></h1>
    <p class="hero-sub"><%= texts.homeTitle %></p>
    <% if (texts.homeBody && texts.homeBody.trim()) { %>
    <p class="hero-text"><%- texts.homeBody.split('\n').join('<br>') %></p>
    <% } %>
    <div class="hero-actions">
      <a class="btn primary" href="/termine">🎺 Alle Termine</a>
      <a class="btn ghost" href="/berichte">Neuigkeiten</a>
    </div>
  </div>
</section>

<% if (next) { const d = fmtDatum(next.datum); %>
<section class="nextgig reveal">
  <div class="nextgig-card">
    <div class="ng-date"><span><%= d.tag %></span><strong><%= d.nr %></strong><span><%= d.monat %></span></div>
    <div class="ng-info">
      <p class="ng-label">Nächster Auftritt</p>
      <h3><%= next.titel %> · <%= next.ort %></h3>
      <p><%= next.zeit %></p>
      <p class="countdown" data-date="<%= next.datum %>"></p>
    </div>
  </div>
</section>
<% } %>

<section class="section reveal">
  <div class="sec-head">
    <h2>Frisch berichtet</h2>
    <a class="more" href="/berichte">Alle Berichte →</a>
  </div>
  <div class="cards">
    <% berichte.forEach((b, i) => { const d = fmtDatum(b.datum); %>
    <a class="card post <%= i === 0 ? 'featured' : '' %>" href="/berichte/<%= b.slug %>">
      <% if (b.bild) { %><div class="card-img"><img loading="lazy" src="<%= b.bild %>" alt=""></div><% } %>
      <div class="card-body">
        <time><%= d.lang %></time>
        <h3><%= b.titel %></h3>
        <p><%= b.body.split('\n')[0].slice(0, i === 0 ? 220 : 120) %>…</p>
        <span class="readmore">Weiterlesen →</span>
      </div>
    </a>
    <% }) %>
  </div>
</section>

<section class="section reveal">
  <div class="sec-head">
    <h2>Wir auf Instagram</h2>
  </div>
  <div class="insta-wrap">
    <aside class="insta-side">
      <img class="insta-logo" src="/media/mirror/logo.png" alt="Latschasorri" onerror="this.style.display='none'">
      <h3>@<%= s.instagramHandle %></h3>
      <p class="insta-name">Partener Latschasorri</p>
      <p class="insta-text">Fotos, Videos und G'schichten direkt vom Umzug – folg üs und verpass koan Auftritt!</p>
      <a class="btn primary" href="https://www.instagram.com/<%= s.instagramHandle %>/" target="_blank" rel="noopener">📸 Folgen</a>
      <a class="btn ghost" href="<%= s.youtube %>" target="_blank" rel="noopener">▶ YouTube</a>
    </aside>
    <div class="insta-main">
      <% if (instaPosts && instaPosts.length) { %>
      <div class="instagrid">
        <% instaPosts.forEach(p => { %>
        <a href="<%= p.link %>" target="_blank" rel="noopener">
          <img loading="lazy" src="<%= p.img %>" alt="<%= p.caption || 'Instagram-Beitrag' %>">
          <% if (p.video) { %><span class="playicon">▶</span><% } %>
          <% if (p.caption) { %><span class="insta-cap"><%= p.caption %></span><% } %>
        </a>
        <% }) %>
      </div>
      <% } else { %>
      <div class="instafeed">
        <% if (s.instagramEmbed) { %>
          <%- s.instagramEmbed %>
        <% } else { %>
          <iframe src="https://www.instagram.com/<%= s.instagramHandle %>/embed" title="Instagram-Feed von @<%= s.instagramHandle %>" loading="lazy" allowtransparency="true" frameborder="0" scrolling="no"></iframe>
        <% } %>
      </div>
      <% } %>
    </div>
  </div>
</section>

<section class="section reveal">
  <div class="sec-head">
    <h2>Aus der Galerie</h2>
    <a class="more" href="/galerie">Zur Galerie →</a>
  </div>
  <div class="masonry small">
    <% galerie.forEach(g => { %>
    <figure class="shot"><img loading="lazy" src="<%= g.bild %>" alt="<%= g.titel %>" data-lightbox></figure>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
